<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- KPV = HMG Emplacement -->

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Turret_KPV"]/label</xpath>
    <value>
      <label>HMG emplacement</label>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Turret_KPV"]/description</xpath>
    <value>
      <description>A heavy machine gun mounted on a tripod.</description>
    </value>
  </Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="Gun_KPV"]/label</xpath>
    <value>
      <label>heavy machine gun</label>
    </value>
  </Operation>

  <!-- M240B = MMG Emplacement -->

