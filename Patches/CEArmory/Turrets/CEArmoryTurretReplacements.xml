<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========== Gatling Gun Emplacement ========== -->

	<Operation Class="PatchOperationReplace">
    <xpath>
      /Defs/ThingDef[defName="CE_Gun_GatlingGun"]
      /verbs/li[@Class="CombatExtended.VerbPropertiesCE"]
      /defaultProjectile
    </xpath>
		<value>
			<defaultProjectile>Bullet_44Magnum_FMJ</defaultProjectile>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
    <xpath>
      /Defs/ThingDef[defName="CE_Gun_GatlingGun"]
      /comps/li[@Class="CombatExtended.CompProperties_AmmoUser"]
      /ammoSet
    </xpath>
		<value>
			<ammoSet>AmmoSet_44Magnum</ammoSet>
		</value>
	</Operation>

	<!-- ========== Mk 19 Grenade Launcher Emplacement ========== -->

  <Operation Class="PatchOperationReplace">
		<xpath>/Defs/ThingDef[defName="CE_Turret_MkNineteenGL"]/label</xpath>
		<value>
			<label>HGL emplacement</label>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>/Defs/ThingDef[defName="CE_Gun_MkNineteenGL"]/label</xpath>
		<value>
			<label>heavy grenade launcher</label>
		</value>
	</Operation>
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="CE_Gun_MkNineteenGL"]/description</xpath>
    <value>
      <description>A heavy grenade launcher attached to a tripod.</description>
    </value>
  </Operation>
	<Operation Class="PatchOperationReplace">
    <xpath>
      /Defs/ThingDef[defName="CE_Gun_MkNineteenGL"]
      /verbs/li[@Class="CombatExtended.VerbPropertiesCE"]
      /defaultProjectile
    </xpath>
		<value>
			<defaultProjectile>Bullet_40x46mmGrenade_HE</defaultProjectile>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
    <xpath>
      /Defs/ThingDef[defName="CE_Gun_MkNineteenGL"]
      /comps/li[@Class="CombatExtended.CompProperties_AmmoUser"]
      /ammoSet
    </xpath>
		<value>
			<ammoSet>AmmoSet_40x46mmGrenade</ammoSet>
		</value>
	</Operation>

	<!-- ========== SPG-9 Recoilless Gun Emplacement ========== -->

